  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "properties": {
          "new_password": {
            "type": "string",
            "maxLength": 128,
            "minLength": 12,
            "title": "New Password"
          },
          "confirmation": {
            "type": "string",
            "maxLength": 128,
            "minLength": 12,
            "title": "Confirmation"
          }
        },
        "type": "object",
        "required": [
          "new_password",
          "confirmation"
        ],
        "title": "ChangePasswordRequest"
      },
      "ConfirmSessionsRequest": {
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Reason",
            "default": "user request"
          },
          "confirm": {
            "type": "boolean",
            "title": "Confirm"
          }
        },
        "type": "object",
        "required": [
          "confirm"
        ],
        "title": "ConfirmSessionsRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
